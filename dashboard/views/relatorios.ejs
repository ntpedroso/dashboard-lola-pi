<%- include ('partials/header.ejs'); %>

  <div class="flex min-h-screen bg-gray-50">
    <%- include('partials/sidebar') %>

      <div class="flex-1 flex flex-col min-w-0">
        <header class="sticky top-0 z-40">
          <%- include('partials/navbar') %>
        </header>

        <main class="text-text font-jakarta text-sm p-4 sm:p-6 lg:p-8 flex flex-col gap-6">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
            <div>
              <p class="hidden lg:block px-2"">
            Home / <span class=" text-salmao font-semibold"> Relatórios </span>
              </p>
            </div>

            <a href="/pacientes"
              class="self-end sm:self-auto flex items-center justify-center w-10 h-10 rounded-full bg-white shadow hover:bg-gray-100 transition"
              title="Voltar">
              <img src="/imgs/icons/back.svg" alt="voltar" class="w-5">
            </a>
          </div>

          <div class="">
            <p class="text-xl text-center md:text-2xl">Relatórios</p>
          </div>

          <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 lg:gap-6">
            <div
              class="bg-white shadow-lg rounded-2xl p-5 lg:p-8 flex flex-col gap-5 justify-between md:col-span-2 xl:col-span-1">
              <p class="text-lg md:text-xl font-semibold text-center">
                Dificuldade por fonema
              </p>

              <div class="relative flex items-center justify-center h-64 sm:h-72">
                <canvas id="graficoFonema"></canvas>
              </div>

              <div class="flex justify-center">
                <a href="/relatorios/fonema"
                  class="w-full sm:w-auto rounded-xl bg-salmao px-5 py-3 text-white text-center hover:bg-salmao/80 transition">
                  Ver detalhes
                </a>
              </div>
            </div>

            <div
              class="bg-white shadow-lg rounded-2xl p-5 lg:p-8 flex flex-col gap-5 justify-between md:col-span-2 xl:col-span-2">
              <p class="text-lg md:text-xl font-semibold text-center">
                Média de Atividade Diária
              </p>

              <div class="relative flex items-center justify-center h-64 sm:h-72 xl:h-80">
                <canvas id="graficoAtividade"></canvas>
              </div>

              <div class="flex justify-center">
                <a href="/relatorios/atividade"
                  class="w-full sm:w-auto rounded-xl bg-salmao px-5 py-3 text-white text-center hover:bg-salmao/80 transition">
                  Ver detalhes
                </a>
              </div>
            </div>

            <div
              class="bg-white shadow-lg rounded-2xl p-5 lg:p-8 flex flex-col gap-5 justify-between md:col-span-2 xl:col-span-1">
              <p class="text-lg md:text-xl font-semibold text-center">
                Evolução de Acertos
              </p>

              <div class="relative flex items-center justify-center h-64 sm:h-72">
                <canvas id="graficoEvolucao"></canvas>
              </div>

              <div class="flex justify-center">
                <a href="#"
                  class="w-full sm:w-auto rounded-xl bg-salmao px-5 py-3 text-white text-center hover:bg-salmao/80 transition">
                  Ver detalhes
                </a>
              </div>
            </div>

            <div class="bg-white shadow-lg rounded-2xl p-5 lg:p-8 flex flex-col gap-5 justify-between">
              <p class="text-lg md:text-xl font-semibold text-center">
                Maior Evolução
              </p>

              <div class="flex flex-col sm:flex-row md:flex-col items-center justify-center gap-6 py-4">
                <div class="flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
                  <img src="/imgs/profile.jpg" alt="foto do paciente"
                    class="rounded-full w-20 h-20 object-cover shadow">

                  <p class="text-base md:text-xl font-semibold">
                    Joana Oliveira
                  </p>
                </div>

                <img src="/imgs/icons/evolucao.svg" alt="ícone de evolução" class="w-24 md:w-28 xl:w-32">
              </div>

              <div class="flex justify-center">
                <a href="#"
                  class="w-full sm:w-auto rounded-xl bg-salmao px-5 py-3 text-white text-center hover:bg-salmao/80 transition">
                  Ver detalhes
                </a>
              </div>
            </div>

            <div
              class="bg-white shadow-lg rounded-2xl p-5 lg:p-8 flex flex-col gap-5 justify-between md:col-span-2 xl:col-span-1">
              <p class="text-lg md:text-xl font-semibold text-center">
                Usuários mais ativos
              </p>

              <div class="flex flex-col gap-4 py-2">
                <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 sm:gap-5">
                  <img src="/imgs/profile.jpg" alt="foto do usuário" class="rounded-full w-11 h-11 object-cover">
                  <p class="text-base md:text-lg">Joana Oliveira</p>
                  <p class="text-base md:text-lg font-semibold">3h52min</p>
                </div>

                <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 sm:gap-5">
                  <img src="/imgs/profile.jpg" alt="foto do usuário" class="rounded-full w-11 h-11 object-cover">
                  <p class="text-base md:text-lg">Joana Oliveira</p>
                  <p class="text-base md:text-lg font-semibold">3h52min</p>
                </div>

                <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 sm:gap-5">
                  <img src="/imgs/profile.jpg" alt="foto do usuário" class="rounded-full w-11 h-11 object-cover">
                  <p class="text-base md:text-lg">Joana Oliveira</p>
                  <p class="text-base md:text-lg font-semibold">3h52min</p>
                </div>
              </div>

              <div class="flex justify-center">
                <a href="#"
                  class="w-full sm:w-auto rounded-xl bg-salmao px-5 py-3 text-white text-center hover:bg-salmao/80 transition">
                  Ver detalhes
                </a>
              </div>
            </div>
          </section>
        </main>
      </div>
  </div>

  <%- include ('partials/footer.ejs'); %>