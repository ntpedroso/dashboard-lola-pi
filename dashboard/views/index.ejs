<%- include ('partials/header.ejs'); %>

<main>
  <div class="flex min-h-screen flex-col font-jakarta xl:flex-row">
    <div class="flex flex-col justify-center items-center bg-salmao min-h-52 md:min-h-72 xl:min-h-screen xl:flex-1 xl:gap-16 px-6 py-8">
      <div class="hidden xl:flex flex-col xl:gap-3 text-center">
        <p class="text-3xl md:text-5xl font-bold text-white">
          Olá, bem-vindo ao
        </p>
        <p class="text-3xl md:text-5xl font-bold text-white">
          Painel Administrativo
        </p>
      </div>

      <img src="/imgs/logo/logo-variante-turquesa.svg" alt="logotipo" class="mt-6 w-44 md:w-64 xl:mt-0 xl:w-96" />

      <div class="hidden xl:grid grid-cols-3 gap-10 2xl:gap-20 text-white pt-10">
        <div class="flex gap-4 items-center">
          <img src="imgs/icons/gestao.svg" alt="" class="w-10" />
          <p>
            Gestão completa <br />
            dos pacientes
          </p>
        </div>

        <div class="flex gap-4 items-center">
          <img src="imgs/icons/relatorio.svg" alt="" class="w-10" />
          <p>
            Relatórios e <br />
            Indicadores
          </p>
        </div>

        <div class="flex gap-4 items-center">
          <img src="imgs/icons/seguranca.svg" alt="" class="w-10" />
          <p>
            Segurança e <br />
            privacidade
          </p>
        </div>
      </div>
    </div>

    <div class="flex flex-1 items-center justify-center text-text bg-fundo px-4 py-8 sm:px-6 lg:px-10">
      <div class="flex w-full max-w-xl flex-col gap-5 rounded-3xl bg-white/70 p-5 sm:p-7 md:p-8 shadow-sm">
        <div>
          <p class="text-2xl md:text-3xl lg:text-4xl pb-3 text-center text-salmao font-light xl:font-medium">
            Entre com sua conta
          </p>

          <p class="text-sm sm:text-base text-text pb-3 text-center font-light">
            Acesse o painel e gerencie as informações dos seus pacientes com praticidade.
          </p>
        </div>

        <form action="/autenticacao" method="POST" class="flex flex-col gap-5">
          <div class="flex flex-col gap-1">
            <label class="text-sm md:text-base font-medium">Usuário</label>
            <input
              type="text"
              name="usuario"
              placeholder="Digite o nome de usuário"
              required
              class="w-full p-3 md:p-4 border border-input-gray bg-white rounded-2xl text-sm md:text-base focus:outline-none focus:ring-turquesa focus:ring-1"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label class="text-sm md:text-base font-medium">Senha</label>
            <input
              type="password"
              name="senha"
              placeholder="Digite sua senha"
              required
              class="w-full p-3 md:p-4 border border-input-gray bg-white rounded-2xl text-sm md:text-base focus:outline-none focus:ring-turquesa focus:ring-1"
            />
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between pt-1">
            <label class="flex items-center gap-2 cursor-pointer">
              <input
                type="checkbox"
                class="w-4 h-4 xl:w-5 xl:h-5 bg-white cursor-pointer border rounded-3xl appearance-none checked:bg-salmao checked:border-turquesa"
              />
              <span class="text-xs md:text-base">Lembre-me</span>
            </label>

            <a href="/alterarSenha" class="text-sm md:text-base text-salmao cursor-pointer">
              Esqueceu a senha?
            </a>
          </div>

          <button
            type="submit"
            class="p-3 md:p-4 md:text-lg border-none rounded-full bg-salmao text-white hover:bg-turquesa transition-colors w-full text-center block"
          >
            Entrar
          </button>

          <div>
            <p class="text-center text-sm md:text-base lg:text-lg">
              ou conecte-se com
            </p>
          </div>

          <div class="flex gap-4 justify-center">
            <a href="#">
              <img src="/imgs/icons/icon-google.svg" class="w-12 lg:w-14 xl:w-auto xl:h-auto" alt="Google" />
            </a>

            <a href="#">
              <img src="/imgs/icons/icon-facebook.svg" class="w-12 lg:w-14 xl:w-auto xl:h-auto" alt="Facebook" />
            </a>
          </div>

          <p class="text-center md:text-base lg:text-lg">
            Não tem uma conta?
            <a href="/cadastroUsuario" class="text-salmao font-semibold">Registre-se</a>
          </p>
        </form>
      </div>
    </div>
  </div>
</main>

<%- include ('partials/footer.ejs'); %>