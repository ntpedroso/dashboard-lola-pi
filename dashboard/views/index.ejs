<%- include ('partials/header.ejs'); %>

    <main>
        <div class="flex flex-col h-screen font-jakarta xl:flex-row">
            <div
                class="flex flex-col justify-center items-center bg-salmao h-48 md:h-64 xl:flex-row xl:flex-1 xl:h-screen">
                <p class="text-3xl md:text-5xl lg:text-6xl font-bold text-white">logotipo</p>
            </div>

            <div class="flex flex-1 items-center justify-center text-text bg-fundo xl:flex-1">
                <div class="flex flex-col p-6 w-90 sm:w-96 md:w-130 lg:w-160 xl:w-120 gap-5">
                    <p class="text-2xl md:text-3xl lg:text-4xl pb-3 text-center text-salmao font-light">Entre com sua
                        conta</p>

                    <div class="flex flex-col gap-1">
                        <label class="text-sm md:text-lg lg:text-xl font-medium">E-mail</label>
                        <input type="text" name="email" placeholder="Digite seu e-mail"
                            class="p-3 md:p-4 lg:p-5 border-none shadow-md bg-white rounded-2xl text-sm lg:text-lg">
                    </div>

                    <div class="flex flex-col gap-1">
                        <label class="text-sm md:text-lg lg:text-xl font-medium">Senha</label>
                        <input type="password" name="senha" placeholder="Digite sua senha"
                            class="p-3 md:p-4 lg:p-5 border-none shadow-md bg-white rounded-2xl text-sm lg:text-lg">
                    </div>

                    <div class="flex justify-between pt-1">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox"
                                class="w-4 h-4 xl:w-5 xl:h-5 bg-white cursor-pointer border rounded-3xl appearance-none checked:bg-salmao checked:border-salmao">
                            <span class="text-xs md:text-base lg:text-lg">Lembre-me</span>
                        </label>
                        <label class="text-sm md:text-base lg:text-lg text-salmao cursor-pointer">Esqueceu a senha?</label>
                    </div>

                    <a href="/home"
                        class="p-2 md:p-3 lg:p-5 lg:text-xl border-none rounded-full bg-salmao text-white hover:bg-turquesa transition-colors w-full text-center block">
                        Entrar
                    </a>

                    <div>
                        <p class="text-center text-sm md:text-base lg:text-lg">ou conecte-se com</p>
                    </div>

                    <div class="flex gap-4 justify-center">
                        <a href="#"><img src="/imgs/icons/icon-google.svg" class="lg:w-16 xl:w-auto xl:h-auto"
                                alt="Google"></a>
                        <a href="#"><img src="/imgs/icons/icon-facebook.svg" class="lg:w-16 xl:w-auto xl:h-auto"
                                alt="Facebook"></a>
                    </div>

                    <p class="text-center md:text-base lg:text-lg">
                        Não tem uma conta? <a href="/cadastroUsuario" class="text-salmao font-semibold">Registre-se</a>
                    </p>
                </div>
            </div>
        </div>
    </main>

    <%- include ('partials/footer.ejs'); %>