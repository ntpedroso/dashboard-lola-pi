<%- include ('partials/header.ejs'); %>

<main>
  <div class="flex flex-col xl:h-screen font-jakarta xl:flex-row">
    <div
      class="flex flex-col justify-center items-center bg-salmao h-48 md:h-64 xl:flex-col xl:gap-20 xl:flex-1 xl:h-screen"
    >
      <div class="flex flex-col xl:gap-3 text-center">
        <p class="text-3xl md:text-5xl font-bold text-white">
          Olá, bem-vindo ao
        </p>
        <p class="text-3xl md:text-5xl font-bold text-white">
          Painel Administrativo
        </p>
      </div>

      <img
        src="/imgs/logo/logo-variante-turquesa.svg"
        alt="logotipo"
        class="xl:w-100"
      />

      <div class="hidden xl:grid grid-cols-3 gap-20 text-white pt-20">
        <div class="flex gap-5">
          <img src="imgs/icons/gestao.svg" alt="" class="w-10" />
          <p>
            Gestão completa <br />
            dos pacientes
          </p>
        </div>
        <div class="flex gap-5">
          <img src="imgs/icons/relatorio.svg" alt="" class="w-10" />
          <p>
            Relatórios e <br />
            Indicadores
          </p>
        </div>
        <div class="flex gap-5">
          <img src="imgs/icons/seguranca.svg" alt="" class="w-10" />
          <p>
            Segurança e <br />
            privacidade
          </p>
        </div>
      </div>
    </div>

    <div
      class="flex flex-1 items-center justify-center text-text bg-fundo xl:flex-1 py-5"
    >
      <div
        class="flex flex-col p-6 w-90 sm:w-96 md:w-130 lg:w-160 xl:w-120 gap-6"
      >
        <p
          class="text-2xl md:text-3xl lg:text-4xl text-center text-salmao font-light"
        >
          Crie uma conta
        </p>

        <div class="flex flex-col gap-1">
          <label class="text-sm md:text-lg font-medium">Nome</label>
          <input
            type="text"
            name="nome"
            placeholder="Digite seu nome"
            required
            class="p-3 md:p-4 border border-input-gray bg-white rounded-2xl text-sm lg:text-lg focus:outline-none focus:ring-turquesa focus:ring-1"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-sm md:text-lg font-medium">Sobrenome</label>
          <input
            type="text"
            name="sobrenome"
            placeholder="Digite seu sobrenome"
            class="p-3 md:p-4 border border-input-gray bg-white rounded-2xl text-sm lg:text-lg focus:outline-none focus:ring-turquesa focus:ring-1"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-sm md:text-lg font-medium">E-mail</label>
          <input
            type="text"
            name="email"
            placeholder="example@email.com"
            class="p-3 md:p-4 border border-input-gray bg-white rounded-2xl text-sm lg:text-lg focus:outline-none focus:ring-turquesa focus:ring-1"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-sm md:text-lg lg:text-xl font-medium">Senha</label>
          <input
            type="password"
            name="senha"
            placeholder="Digite sua senha"
            class="p-3 md:p-4 border border-input-gray bg-white rounded-2xl text-sm lg:text-lg focus:outline-none focus:ring-turquesa focus:ring-1"
          />
        </div>

        <a
          href="/home"
          class="p-2 md:p-3 lg:p-4 lg:text-xl border-none rounded-full bg-salmao text-white hover:bg-turquesa transition-colors w-full text-center block"
        >
          Cadastrar
        </a>

        <div>
          <p class="text-center md:text-base lg:text-lg">
            Já tem uma conta?
            <a href="/" class="text-salmao font-semibold">Entrar</a>
          </p>
        </div>

        <div>
          <p class="text-center text-sm md:text-base lg:text-lg">
            ou conecte-se com
          </p>
        </div>

        <div class="flex gap-4 justify-center">
          <a href="#"
            ><img
              src="/imgs/icons/icon-google.svg"
              class="lg:w-16 xl:w-auto xl:h-auto"
              alt="Google"
          /></a>
          <a href="#"
            ><img
              src="/imgs/icons/icon-facebook.svg"
              class="lg:w-16 xl:w-auto xl:h-auto"
              alt="Facebook"
          /></a>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include ('partials/footer.ejs'); %>
