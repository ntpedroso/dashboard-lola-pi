<%- include ('partials/header.ejs'); %>

<main>
  <div class="flex min-h-screen flex-col font-jakarta xl:flex-row">
    <div class="flex flex-col justify-center items-center bg-salmao min-h-52 md:min-h-72 xl:min-h-screen xl:flex-1 xl:gap-16 px-6 py-8">
      <div class="flex flex-col xl:gap-3 text-center">
        <p class="text-3xl md:text-5xl font-bold text-white">
          Olá, bem-vindo ao
        </p>

        <p class="text-3xl md:text-5xl font-bold text-white">
          Painel Administrativo
        </p>
      </div>

      <img
        src="/imgs/logo/logo-variante-turquesa.svg"
        alt="logotipo"
        class="mt-6 w-44 md:w-64 xl:mt-0 xl:w-96"
      />

      <div class="hidden xl:grid grid-cols-3 gap-10 2xl:gap-20 text-white pt-10">
        <div class="flex gap-4 items-center">
          <img src="imgs/icons/gestao.svg" alt="" class="w-10" />
          <p>
            Gestão completa <br />
            dos pacientes
          </p>
        </div>

        <div class="flex gap-4 items-center">
          <img src="imgs/icons/relatorio.svg" alt="" class="w-10" />
          <p>
            Relatórios e <br />
            Indicadores
          </p>
        </div>

        <div class="flex gap-4 items-center">
          <img src="imgs/icons/seguranca.svg" alt="" class="w-10" />
          <p>
            Segurança e <br />
            privacidade
          </p>
        </div>
      </div>
    </div>

    <div class="flex flex-1 items-center justify-center text-text bg-fundo px-4 py-8 sm:px-6 lg:px-10">
      <div class="flex w-full max-w-xl flex-col gap-5 rounded-3xl bg-white/70 p-5 sm:p-7 md:p-8 shadow-sm">
        <div>
          <p class="text-2xl md:text-3xl lg:text-4xl pb-3 text-center text-salmao font-light">
            Alterar Senha
          </p>

          <p class="text-sm sm:text-base text-text/70 text-center font-light">
            Primeiro informe o nome de usuário. Depois cadastre uma nova senha.
          </p>
        </div>

        <% if (typeof erro !== "undefined" && erro) { %>
          <div class="rounded-2xl border border-red-300 bg-red-50 px-4 py-3 text-sm md:text-base text-red-700 text-center">
            <%= erro %>
          </div>
        <% } %>

        <% if (typeof sucesso !== "undefined" && sucesso) { %>
          <div class="rounded-2xl border border-green-300 bg-green-50 px-4 py-3 text-sm md:text-base text-green-700 text-center">
            <%= sucesso %>
          </div>
        <% } %>

        <% if (!usuarioEncontrado) { %>
          <form action="/alterarSenha/procurar" method="POST" class="flex flex-col gap-5">
            <div class="flex flex-col gap-1">
              <label class="text-sm md:text-base font-medium">
                Nome de usuário
              </label>

              <input
                type="text"
                name="usuario"
                placeholder="Digite o nome de usuário"
                required
                class="w-full p-3 md:p-4 border border-input-gray shadow-sm bg-white rounded-2xl text-sm md:text-base focus:outline-none focus:ring-turquesa focus:ring-1"
              />
            </div>

            <button
              type="submit"
              class="p-3 md:p-4 md:text-lg border-none rounded-full bg-salmao text-white hover:bg-turquesa transition-colors w-full text-center block"
            >
              Procurar usuário
            </button>

            <div>
              <a href="/">
                <p class="text-center text-salmao text-sm md:text-base lg:text-lg">
                  voltar ao Login
                </p>
              </a>
            </div>
          </form>
        <% } %>

        <% if (usuarioEncontrado) { %>
          <form action="/alterarSenha/salvar" method="POST" class="flex flex-col gap-5">
            <input type="hidden" name="id" value="<%= usuarioEncontrado.id %>">
            <input type="hidden" name="usuario" value="<%= usuarioEncontrado.usuario %>">

            <div class="rounded-2xl bg-turquesa/10 px-4 py-3 text-center">
              <p class="text-sm text-text/70">
                Alterando senha de:
              </p>

              <p class="font-semibold text-salmao">
                <%= usuarioEncontrado.usuario %>
              </p>
            </div>

            <div class="flex flex-col gap-1">
              <label class="text-sm md:text-base font-medium">
                Nova Senha
              </label>

              <input
                type="password"
                name="novaSenha"
                placeholder="Digite a nova senha"
                required
                class="w-full p-3 md:p-4 border border-input-gray shadow-sm bg-white rounded-2xl text-sm md:text-base focus:outline-none focus:ring-turquesa focus:ring-1"
              />
            </div>

            <div class="flex flex-col gap-1">
              <label class="text-sm md:text-base font-medium">
                Confirme a senha
              </label>

              <input
                type="password"
                name="confirmarSenha"
                placeholder="Digite novamente a senha"
                required
                class="w-full p-3 md:p-4 border border-input-gray shadow-sm bg-white rounded-2xl text-sm md:text-base focus:outline-none focus:ring-turquesa focus:ring-1"
              />
            </div>

            <button
              type="submit"
              class="p-3 md:p-4 md:text-lg border-none rounded-full bg-salmao text-white hover:bg-turquesa transition-colors w-full text-center block"
            >
              Alterar senha
            </button>

            <div class="flex justify-center gap-4">
              <a href="/alterarSenha">
                <p class="text-center text-turquesa text-sm md:text-base lg:text-lg">
                  procurar outro usuário
                </p>
              </a>

              <a href="/">
                <p class="text-center text-salmao text-sm md:text-base lg:text-lg">
                  voltar ao Login
                </p>
              </a>
            </div>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</main>

<%- include ('partials/footer.ejs'); %>