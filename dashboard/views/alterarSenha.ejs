<%- include ('partials/header.ejs'); %>

<main>
  <div class="flex flex-col h-screen font-jakarta xl:flex-row">
    <div
      class="flex flex-col justify-center items-center bg-salmao h-48 md:h-64 xl:flex-col xl:gap-20 xl:flex-1 xl:h-screen"
    >
      <div class="flex flex-col xl:gap-3 text-center">
        <p class="text-3xl md:text-5xl font-bold text-white">
          Olá, bem-vindo ao
        </p>
        <p class="text-3xl md:text-5xl font-bold text-white">
          Painel Administrativo
        </p>
      </div>

      <img
        src="/imgs/logo/logo-variante-turquesa.svg"
        alt="logotipo"
        class="xl:w-100"
      />

      <div class="hidden xl:grid grid-cols-3 gap-20 text-white pt-20">
        <div class="flex gap-5">
          <img src="imgs/icons/gestao.svg" alt="" class="w-10" />
          <p>
            Gestão completa <br />
            dos pacientes
          </p>
        </div>
        <div class="flex gap-5">
          <img src="imgs/icons/relatorio.svg" alt="" class="w-10" />
          <p>
            Relatórios e <br />
            Indicadores
          </p>
        </div>
        <div class="flex gap-5">
          <img src="imgs/icons/seguranca.svg" alt="" class="w-10" />
          <p>
            Segurança e <br />
            privacidade
          </p>
        </div>
      </div>
    </div>

    <div
      class="flex flex-1 items-center justify-center text-text bg-fundo xl:flex-1"
    >
      <div
        class="flex flex-col p-6 w-90 sm:w-96 md:w-130 lg:w-160 xl:w-120 gap-5"
      >
        <p
          class="text-2xl md:text-3xl lg:text-4xl pb-3 text-center text-salmao font-light"
        >
          Alterar Senha
        </p>

        <div class="flex flex-col gap-1">
          <label class="text-sm md:text-lg font-medium">Nova Senha</label>
          <input
            type="text"
            name="senha"
            placeholder="Digite a nova senha"
            class="p-3 md:p-4 border border-input-gray shadow-md bg-white rounded-2xl text-sm lg:text-base focus:outline-none focus:ring-turquesa focus:ring-1"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-sm md:text-lg font-medium">Confirme a senha</label>
          <input
            type="password"
            name="senha"
            placeholder="Digite novamente a senha"
            class="p-3 md:p-4 border border-input-gray shadow-md bg-white rounded-2xl text-sm lg:text-base focus:outline-none focus:ring-turquesa focus:ring-1"
          />
        </div>

        <a
          href="/"
          class="p-2 md:p-3 lg:p-4 lg:text-xl border-none rounded-full bg-salmao text-white hover:bg-turquesa transition-colors w-full text-center block"
        >
          Alterar
        </a>

        <div>
          <a href="/"
            ><p class="text-center text-salmao text-sm md:text-base lg:text-lg">
              voltar ao Login
            </p></a
          >
        </div>
      </div>
    </div>
  </div>
</main>

<%- include ('partials/footer.ejs'); %>
