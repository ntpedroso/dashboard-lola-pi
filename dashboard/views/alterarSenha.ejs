<%- include ('partials/header.ejs'); %>

    <main>
        <div class="flex flex-col h-screen font-jakarta xl:flex-row">
            <div
                class="flex flex-col justify-center items-center bg-salmao h-48 md:h-64 xl:flex-row xl:flex-1 xl:h-screen">
                <p class="text-3xl md:text-5xl lg:text-6xl font-bold text-white">logotipo</p>
            </div>

            <div class="flex flex-1 items-center justify-center text-text bg-fundo xl:flex-1">
                <div class="flex flex-col p-6 w-90 sm:w-96 md:w-130 lg:w-160 xl:w-120 gap-5">
                    <p class="text-2xl md:text-3xl lg:text-4xl pb-3 text-center text-salmao font-light">Alterar Senha</p>

                    <div class="flex flex-col gap-1">
                        <label class="text-sm md:text-lg  font-medium">Nova Senha</label>
                        <input type="text" name="senha" placeholder="Digite a nova senha"
                            class="p-3 md:p-4 border-none shadow-md bg-white rounded-2xl text-sm lg:text-base focus:outline-none focus:ring-turquesa focus:ring-1">
                    </div>

                    <div class="flex flex-col gap-1">
                        <label class="text-sm md:text-lg font-medium">Confirme a senha</label>
                        <input type="password" name="senha" placeholder="Digite novamente a senha"
                            class="p-3 md:p-4  border-none shadow-md bg-white rounded-2xl text-sm lg:text-base focus:outline-none focus:ring-turquesa focus:ring-1">
                    </div>

                    <a href="/"
                        class="p-2 md:p-3 lg:p-4 lg:text-xl border-none rounded-full bg-salmao text-white hover:bg-turquesa transition-colors w-full text-center block">
                        Alterar
                    </a>

                    <div>
                        <a href="/"><p class="text-center text-salmao text-sm md:text-base lg:text-lg">voltar ao Login</p></a>
                    </div>

                </div>
            </div>
        </div>
    </main>

    <%- include ('partials/footer.ejs'); %>