                                <li class="list-disc">Maior dificuldade na consoante /s/</li>
                            </ul>
                            <div class="flex justify-center py-3 gap-3">
                                <a href="" class="p-4 md:p-3 bg-roxo rounded-sm xl:p-4 xl:hover:bg-roxo/75">
                                    <p class="text-white">Ver tudo</p>
                                </a>
                                <a href="" class="p-4 md:p-3 bg-turquesa xl:hover:bg-turquesa/75 rounded-sm xl:p-4">
                                    <img src="/imgs/icons/editar.svg" class="w-5 md:w-5">
                                </a>
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-x-3 gap-y-8">
