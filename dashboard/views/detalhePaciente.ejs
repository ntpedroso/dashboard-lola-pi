                                <a href=""
                                    class="block p-4 md:p-3 bg-turquesa rounded-sm xl:p-4 xl:hover:bg-turquesa/75">
                                    <img src="/imgs/icons/editar.svg" class="w-5 md:w-5 ">
                                </a>
                                <a href=""
                                    class="block p-4 md:p-3 bg-salmao xl:hover:bg-amarelo/75 rounded-sm  md:block xl:p-4">
                                    <img src="/imgs/icons/excluir.svg" class="w-5 md:w-5">
                                </a>

                            </div>
                        </div>
                        <div class="bg-white shadow-lg rounded-xl p-8 flex flex-col gap-3">
