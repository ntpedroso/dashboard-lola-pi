                                <a href="" class="px-4 py-2 bg-turquesa rounded-lg text-sm">Ver relatório</a>
                            </div>
                            <div class="col-span-2 bg-white shadow-xl rounded-lg p-8 flex flex-col gap-5">
                                <div>
                                    <p class="text-lg font-semibold">Desempenho por fonema</p>
                                    <p class="text-sm text-text/75">Taxa de Acertos</p>
                                </div>
                                <div>
                                    gráfico
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
    </div>

    <%- include ('partials/footer.ejs'); %>
        </div>