<%- include ('partials/header.ejs'); %>

<div class="flex min-h-screen bg-gray-50">
  <%- include('partials/sidebar') %>

  <div class="flex-1 flex flex-col min-w-0">
    <header class="sticky top-0 z-40">
      <%- include('partials/navbar') %>
    </header>

    <main class="flex flex-col gap-6 bg-fundo px-4 py-5 font-jakarta text-text sm:px-6 lg:px-8">

      <section class="flex items-center justify-between lg:hidden">
        <div>
          <p class="text-sm text-text/70 sm:text-base">Olá,</p>
          <p class="text-xl font-semibold sm:text-2xl">
            Natasha Pedroso!
          </p>
        </div>

        <div class="h-14 w-14 overflow-hidden rounded-2xl shadow-md sm:h-16 sm:w-16">
          <img
            src="/imgs/profile.jpg"
            class="h-full w-full object-cover"
            alt="Foto de perfil"
          />
        </div>
      </section>

      <section
        class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-5"
      >
        <a
          href="/pacientes"
          class="group cursor-pointer rounded-3xl bg-white p-5 shadow-lg transition duration-200 hover:-translate-y-1 hover:scale-[1.02] hover:shadow-xl"
        >
          <div class="flex h-full flex-col justify-between gap-5">
            <div>
              <p class="text-sm text-text/60 md:text-base">
                Pacientes Cadastrados
              </p>
            </div>

            <div class="flex items-end justify-between">
              <p class="text-4xl font-bold text-salmao lg:text-5xl">
                8
              </p>

              <div
                class="flex h-14 w-14 items-center justify-center rounded-2xl bg-salmao/10 transition group-hover:bg-salmao/20"
              >
                <img src="/imgs/icons/user.svg" alt="" class="w-8" />
              </div>
            </div>
          </div>
        </a>

        <a
          href="/relatorios/acertos"
          class="group cursor-pointer rounded-3xl bg-white p-5 shadow-lg transition duration-200 hover:-translate-y-1 hover:scale-[1.02] hover:shadow-xl"
        >
          <div class="flex h-full flex-col justify-between gap-5">
            <div>
              <p class="text-sm text-text/60 md:text-base">
                Média de Acertos
              </p>
            </div>

            <div class="flex items-end justify-between">
              <p class="text-4xl font-bold text-salmao lg:text-5xl">
                47,5%
              </p>

              <div
                class="flex h-14 w-14 items-center justify-center rounded-2xl bg-turquesa/10 transition group-hover:bg-turquesa/20"
              >
                <img src="/imgs/icons/acerto.svg" alt="" class="w-8" />
              </div>
            </div>
          </div>
        </a>

        <a
          href="/relatorios/atividade"
          class="group cursor-pointer rounded-3xl bg-white p-5 shadow-lg transition duration-200 hover:-translate-y-1 hover:scale-[1.02] hover:shadow-xl"
        >
          <div class="flex h-full flex-col justify-between gap-5">
            <div>
              <p class="text-sm text-text/60 md:text-base">
                Tempo Médio de Prática
              </p>
            </div>

            <div class="flex items-end justify-between">
              <p class="text-4xl font-bold text-salmao lg:text-5xl">
                37min
              </p>

              <div
                class="flex h-14 w-14 items-center justify-center rounded-2xl bg-roxo/10 transition group-hover:bg-roxo/20"
              >
                <img src="/imgs/icons/clock.svg" alt="" class="w-8" />
              </div>
            </div>
          </div>
        </a>

        <a
          href="/usuarios/inativos"
          class="group cursor-pointer rounded-3xl bg-gradient-to-br from-salmao to-salmao/80 p-5 text-white shadow-lg transition duration-200 hover:-translate-y-1 hover:scale-[1.02] hover:shadow-xl sm:col-span-2 xl:col-span-2"
        >
          <div class="flex h-full flex-col justify-between gap-5">
            <div>
              <p class="text-sm text-white/70 md:text-base">
                Usuários Inativos
              </p>
            </div>

            <div class="flex items-end justify-between">
              <p class="text-5xl font-bold">
                2
              </p>

              <div
                class="rounded-2xl bg-white/10 px-4 py-2 text-sm backdrop-blur-sm transition group-hover:bg-white/20"
              >
                Requer atenção
              </div>
            </div>
          </div>
        </a>
      </section>

      <section class="grid grid-cols-1 gap-5 xl:grid-cols-5">
        <div
          class="rounded-3xl bg-white p-5 shadow-lg xl:col-span-3"
        >
          <div class="flex items-center justify-between">
            <div>
              <p class="text-lg font-semibold lg:text-xl">
                Atividade Diária
              </p>

              <p class="text-sm text-text/60">
                em minutos
              </p>
            </div>

            <a
              href="/relatorios/atividade"
              class="rounded-full bg-salmao/10 px-4 py-2 text-sm font-medium text-salmao transition hover:bg-salmao hover:text-white"
            >
              Ver relatório
            </a>
          </div>

          <div class="mt-6 flex h-72 sm:h-80">
            <canvas id="graficoAtividadeHome"></canvas>
          </div>
        </div>

        <div
          class="rounded-3xl bg-white p-5 shadow-lg xl:col-span-2"
        >
          <div class="flex items-center justify-between">
            <div>
              <p class="text-lg font-semibold lg:text-xl">
                Calendário
              </p>

              <p class="text-sm text-text/60">
                sessões e atividades
              </p>
            </div>
          </div>

          <div
            class="mt-6 flex h-72 items-center justify-center rounded-2xl bg-gray-50 text-text/40"
          >
            calendário mensal
          </div>
        </div>
      </section>

      <section class="rounded-3xl bg-white p-5 shadow-lg">
        <div class="flex items-center justify-between gap-3">
          <div class="grid gap-2">
            <p class="text-lg font-semibold lg:text-xl">
              Pacientes
            </p>
          </div>

          <a
            href="/pacientes"
            class="rounded-full bg-salmao px-4 py-2 text-sm font-medium text-white transition hover:bg-salmao/80"
          >
            Ver todos
          </a>
        </div>

        <div class="mt-6 overflow-x-auto">
          <div class="min-w-[650px]">

            <div
              class="grid grid-cols-[40px_60px_2fr_1fr_1fr] items-center border-b border-text/10 pb-4 text-sm font-semibold text-text/60"
            >
              <span></span>
              <span></span>
              <span>Nome</span>
              <span>Nível</span>
              <span>Status</span>
            </div>

            <a
              href="#"
              class="grid grid-cols-[40px_60px_2fr_1fr_1fr] items-center border-b border-text/5 py-4 text-sm transition hover:bg-gray-50"
            >
              <span class="font-semibold">1</span>

              <span>
                <img
                  src="/imgs/profile.jpg"
                  class="h-10 w-10 rounded-full object-cover"
                />
              </span>

              <span class="font-medium">
                Pedro Henrique
              </span>

              <span>
                Nível 1
              </span>

              <span>
                <span
                  class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700"
                >
                  Ativo
                </span>
              </span>
            </a>

            <a
              href="#"
              class="grid grid-cols-[40px_60px_2fr_1fr_1fr] items-center border-b border-text/5 py-4 text-sm transition hover:bg-gray-50"
            >
              <span class="font-semibold">2</span>

              <span>
                <img
                  src="/imgs/profile.jpg"
                  class="h-10 w-10 rounded-full object-cover"
                />
              </span>

              <span class="font-medium">
                Maria Eduarda
              </span>

              <span>
                Nível 2
              </span>

              <span>
                <span
                  class="rounded-full bg-yellow-100 px-3 py-1 text-xs font-medium text-yellow-700"
                >
                  Inativo
                </span>
              </span>
            </a>

            <a
              href="#"
              class="grid grid-cols-[40px_60px_2fr_1fr_1fr] items-center py-4 text-sm transition hover:bg-gray-50"
            >
              <span class="font-semibold">3</span>

              <span>
                <img
                  src="/imgs/profile.jpg"
                  class="h-10 w-10 rounded-full object-cover"
                />
              </span>

              <span class="font-medium">
                João Oliveira
              </span>

              <span>
                Nível 3
              </span>

              <span>
                <span
                  class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700"
                >
                  Ativo
                </span>
              </span>
            </a>

          </div>
        </div>
      </section>
    </main>
  </div>
</div>

<%- include ('partials/footer.ejs'); %>