<%- include ('partials/header.ejs'); %>

<div class="flex min-h-screen bg-gray-50">
  <%- include('partials/sidebar') %>

  <div class="flex-1 flex flex-col min-w-0">

    <header class="sticky top-0 z-40">
      <%- include('partials/navbar') %>
    </header>

    <main class="flex flex-col gap-6 p-6 font-jakarta text-sm text-text md:p-10">

      
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">

        <p class="hidden px-2 lg:block">
          Home /
          <span class="font-semibold text-salmao">Perfil</span>
        </p>

        <a
          href="/home"
          class="flex h-11 w-11 items-center justify-center self-end rounded-full bg-white shadow-md transition hover:bg-gray-100 sm:self-auto"
          title="Voltar"
        >
          <img src="/imgs/icons/back.svg" alt="voltar" class="w-5" />
        </a>

      </div>

      <section class="w-full">

        <div class="overflow-hidden rounded-[32px] border border-gray-100 bg-white shadow-sm">

          <div class="h-40 bg-gradient-to-r from-[#EF847C] to-[#F3A09A] sm:h-52"></div>

          <div class="px-8 pb-12 sm:px-12">

            <div class="-mt-16 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">

              <div class="flex flex-col items-center gap-5 sm:flex-row sm:items-end">

                <img
                  src="<%= fono.foto_perfil || '/imgs/profile.jpg' %>"
                  alt="Foto de perfil"
                  class="h-32 w-32 rounded-full border-4 border-white object-cover shadow-lg flex-shrink-0"
                />

                <div class="pb-2 text-center sm:text-left">
                  <h2 class="text-3xl font-bold text-gray-800">
                    <%= fono.nome %>
                  </h2>
                  <p class="mt-1 text-base text-gray-500">Fonoaudióloga</p>
                </div>

              </div>

              <!-- BOTÃO -->
              <div class="pb-2">
                <button
                  class="w-full rounded-2xl bg-[#EF847C] px-8 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#e56f66] sm:w-auto"
                >
                  Editar Perfil
                </button>
              </div>

            </div>

            <!-- CARDS -->
            <div class="mt-10 grid grid-cols-1 gap-8 xl:grid-cols-3">

              <!-- DADOS PESSOAIS -->
              <div class="rounded-3xl border border-gray-100 p-8 shadow-sm xl:col-span-2">

                <h3 class="mb-7 text-xl font-semibold text-gray-800">Dados Pessoais</h3>

                <div class="grid grid-cols-1 gap-5 md:grid-cols-2">

                  <!-- NOME -->
                  <div class="rounded-2xl bg-gray-50 px-6 py-5">
                    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Nome</p>
                    <p class="mt-2.5 text-base font-medium text-gray-700"><%= fono.nome %></p>
                  </div>

                  <!-- EMAIL -->
                  <div class="rounded-2xl bg-gray-50 px-6 py-5">
                    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Email</p>
                    <p class="mt-2.5 break-all text-base font-medium text-gray-700"><%= fono.email %></p>
                  </div>

                  <!-- CRFA -->
                  <div class="rounded-2xl bg-gray-50 px-6 py-5">
                    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">CRFa</p>
                    <p class="mt-2.5 text-base font-medium text-gray-700"><%= fono.crfa %></p>
                  </div>

                  <!-- TELEFONE -->
                  <div class="rounded-2xl bg-gray-50 px-6 py-5">
                    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Telefone</p>
                    <p class="mt-2.5 text-base font-medium text-gray-700"><%= fono.telefone %></p>
                  </div>

                </div>

              </div>

              <!-- PERFIL -->
              <div class="rounded-3xl border border-gray-100 p-8 shadow-sm">

                <h3 class="mb-7 text-xl font-semibold text-gray-800">Perfil</h3>

                <div class="flex flex-col gap-5">

                  <!-- CARGO -->
                  <div class="rounded-2xl bg-gray-50 px-6 py-5">
                    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Cargo</p>
                    <p class="mt-2.5 text-base font-semibold text-gray-700"><%= usuario.tipo %></p>
                  </div>

                  <!-- STATUS -->
                  <div class="rounded-2xl bg-gray-50 px-6 py-5">
                    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Status</p>
                    <span class="mt-3 inline-flex rounded-full bg-green-100 px-4 py-1.5 text-xs font-semibold text-green-700">
                      Ativo
                    </span>
                  </div>

                </div>

              </div>

            </div>

          </div>

        </div>

      </section>

    </main>

  </div>
</div>

<%- include ('partials/footer.ejs'); %>
