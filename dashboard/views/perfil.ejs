<%- include ('partials/header.ejs'); %>

  <div class="flex min-h-screen bg-[#f6f7fb]">
    <%- include('partials/sidebar') %>

      <div class="flex flex-1 flex-col min-w-0">

        <header class="sticky top-0 z-40">
          <%- include('partials/navbar') %>
        </header>

        <main class="flex flex-col gap-8 p-4 sm:p-6 lg:p-8 xl:p-10 font-jakarta text-text">

          <div class="flex items-center justify-between">

            <div>
              <p class="text-sm text-text/50">
                Home /
                <span class="font-semibold text-salmao">
                  Perfil
                </span>
              </p>
            </div>

            <a href="/home"
              class="flex h-11 w-11 items-center justify-center rounded-full bg-white shadow-md transition hover:bg-gray-100">
              <img src="/imgs/icons/back.svg" alt="" class="w-5">
            </a>

          </div>

          <section class="overflow-hidden rounded-[34px] bg-white shadow-sm border border-gray-100">

            <div class="h-20 bg-gradient-to-r from-salmao to-[#F2A39C] sm:h-30"></div>

            <div class="px-5 pb-8 sm:px-8 lg:px-10">

              <div class="-mt-16 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">

                <div class="flex flex-col items-center gap-5 sm:flex-row sm:items-end">

                  <div class="relative">

                    <div
                      class="h-32 w-32 overflow-hidden rounded-full border-[5px] border-white bg-white shadow-xl sm:h-36 sm:w-36">
                      <img src="<%= fono.foto_perfil || '/imgs/profile.png' %>" alt=""
                        class="h-full w-full object-cover object-center">
                    </div>

                    <span
                      class="absolute bottom-2 right-2 h-5 w-5 rounded-full border-4 border-white bg-green-400"></span>

                  </div>

                  <div class="flex flex-col gap-5 pb-2 text-center sm:text-left p-8 ">

                    <h2 class="text-3xl font-bold text-gray-800 sm:text-4xl">
                      <%= fono.nome %>
                    </h2>

                    <p class="mt-2 text-base text-text/60">
                      Fonoaudióloga • Painel Administrativo Lolá
                    </p>

                    <div class="mt-4 flex flex-wrap items-center justify-center gap-3 sm:justify-start">

                      <span class="rounded-full bg-salmao/10 px-4 py-2 text-sm font-medium text-salmao">
                        CRFa <%= fono.crfa %>
                      </span>

                      <span class="rounded-full bg-green-100 px-4 py-2 text-sm font-medium text-green-700">
                        Conta ativa
                      </span>

                    </div>

                  </div>

                </div>

                <div class="flex flex-col gap-3 sm:flex-row">

                  <a href="/perfil/editar"
                    class="rounded-2xl bg-salmao px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#e56f66]">
                    Editar Perfil
                  </a>

                </div>

              </div>

            </div>

          </section>

          <section class="grid grid-cols-1 gap-6 2xl:grid-cols-[1.6fr_1fr]">

            <div class="flex flex-col gap-6">

              <div class="rounded-[30px] border border-gray-100 bg-white p-6 shadow-sm sm:p-8">

                <div class="gap-5 p-2 flex items-center justify-between">

                  <div>
                    <h3 class="text-xl font-semibold text-gray-800">
                      Informações pessoais
                    </h3>

                    <p class="mt-1 text-sm text-text/50">
                      Dados principais da conta profissional
                    </p>
                  </div>

                </div>

                <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">

                  <div class="rounded-3xl bg-[#f8f9fc] p-6">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-text/35">
                      Nome completo
                    </p>

                    <p class="mt-4 text-lg font-semibold text-gray-800">
                      <%= fono.nome %>
                    </p>
                  </div>

                  <div class="rounded-3xl bg-[#f8f9fc] p-6">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-text/35">
                      Email
                    </p>

                    <p class="mt-4 break-all text-lg font-semibold text-gray-800">
                      <%= fono.email %>
                    </p>
                  </div>

                  <div class="rounded-3xl bg-[#f8f9fc] p-6">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-text/35">
                      Telefone
                    </p>

                    <p class="mt-4 text-lg font-semibold text-gray-800">
                      <%= fono.telefone %>
                    </p>
                  </div>

                  <div class="rounded-3xl bg-[#f8f9fc] p-6">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-text/35">
                      CRFa
                    </p>

                    <p class="mt-4 text-lg font-semibold text-gray-800">
                      <%= fono.crfa %>
                    </p>
                  </div>

                </div>

              </div>

              <div class="rounded-[30px] border border-gray-100 bg-white p-6 shadow-sm sm:p-8">

                <div class="mb-8">
                  <h3 class="text-xl font-semibold text-gray-800">
                    Sobre o perfil
                  </h3>

                  <p class="mt-1 text-sm text-text/50">
                    Resumo geral da atuação profissional
                  </p>
                </div>

                <div class="grid grid-cols-1 gap-5 md:grid-cols-3">

                  <div class="rounded-3xl bg-[#f8f9fc] p-6 text-center">
                    <p class="text-sm text-text/50">
                      Pacientes ativos
                    </p>

                    <p class="mt-3 text-4xl font-bold text-salmao">
                      6
                    </p>
                  </div>

                  <div class="rounded-3xl bg-[#f8f9fc] p-6 text-center">
                    <p class="text-sm text-text/50">
                      Relatórios emitidos
                    </p>

                    <p class="mt-3 text-4xl font-bold text-salmao">
                      42
                    </p>
                  </div>

                  <div class="rounded-3xl bg-[#f8f9fc] p-6 text-center">
                    <p class="text-sm text-text/50">
                      Tempo na plataforma
                    </p>

                    <p class="mt-3 text-4xl font-bold text-salmao">
                      2a
                    </p>
                  </div>

                </div>

              </div>

            </div>

            <div class="flex flex-col gap-6">

              <div class="rounded-[30px] border border-gray-100 bg-white p-6 shadow-sm sm:p-8">

                <div class="mb-8">
                  <h3 class="text-xl font-semibold text-gray-800">
                    Conta
                  </h3>

                  <p class="mt-1 text-sm text-text/50">
                    Informações do acesso ao sistema
                  </p>
                </div>

                <div class="flex flex-col gap-5">

                  <div class="rounded-3xl bg-[#f8f9fc] p-6">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-text/35">
                      Tipo de conta
                    </p>

                    <p class="mt-4 text-lg font-semibold text-gray-800">
                      <%= usuario.tipo %>
                    </p>
                  </div>

                  <div class="rounded-3xl bg-[#f8f9fc] p-6">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-text/35">
                      Status da conta
                    </p>

                    <div class="py-6">
                      <span class="rounded-full bg-green-100 px-4 py-2 text-sm font-semibold text-green-700">
                        Conta ativa
                      </span>
                    </div>
                  </div>

                  <div class="rounded-3xl bg-[#f8f9fc] p-6">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-text/35">
                      Último acesso
                    </p>

                    <p class="mt-4 text-lg font-semibold text-gray-800">
                      Hoje às 19:42
                    </p>
                  </div>

                </div>

              </div>



            </div>

          </section>

        </main>

      </div>
  </div>

  <%- include ('partials/footer.ejs'); %>